[
    {
        "output": "eDP-1",
        "layer": "top",
        "spacing": 0,
        "height": 0,

        "margin-top": 8,
        "margin-right": 8,
        "margin-bottom": 0,
        "margin-left": 8,

        "modules-left": [
            "hyprland/workspaces#laptop"
        ],

        "modules-center": [
            "clock#laptop"
        ],

        "modules-right": [
            "tray#laptop",
            "wireplumber#laptop",
            "cpu#laptop",
            "memory#laptop",
            "network#laptop",
            "battery"
        ],

        "hyprland/workspaces#laptop": {
            "disable-scroll": true,
            "all-outputs": false,
            "tooltip": false
        },

        "tray#laptop": {
            "spacing": 10,
            "tooltip": false
        },

        "clock#laptop": {
            "format": "{:%I:%M %p - %a, %d %b %Y}",
            "interval": 60,
            "tooltip": false
        },

        "cpu#laptop": {
            "format": "󰻠 {usage}%",
            "interval": 10,
            "states": {
                "critical": 90
            }
        },

        "memory#laptop": {
            "format": "󰍛 {percentage}%",
            "interval": 10,
            "states": {
                "critical": 80
            }
        },

        "battery": {
            "bat": "BAT1",
            "format": "󰁹 {capacity}%",
            "format-charging": "󰂄 {capacity}%",
            "format-plugged": "󰁹 {capacity}%",
            "interval": 60,
            "states": {
                "warning": 20,
                "critical": 10
            },
            "tooltip": false
        },

        "network#laptop": {
            "format-wifi": "󰤨 {bandwidthDownBits}",
            "format-ethernet": "󰈀 {bandwidthDownBits}",
            "format-disconnected": "󰤭",
            "interval": 30,
            "tooltip": false
        },

        "wireplumber#laptop": {
            "scroll-step": 5,
            "max-volume": 100,
            "format": "󰕾 {volume}%",
            "format-muted": "󰖁",
            "format-bluetooth": "󰕾 {volume}%",
            "on-click": "pavucontrol",
            "tooltip": false
        }
    },
    {
